R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
WORKER_POLL_INTERVAL_SECONDS=3
WORKER_BATCH_SIZE=2
WORKER_NAME=local-worker
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
